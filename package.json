{
  "name": "polyfill-bundler",
  "version": "1.0.127",
  "license": "CC-BY-3.0",
  "description": "Polyfill service.",
  "homepage": "https://torben.website/polyfill-bundler",
  "documentationWebsite": {
    "languages": [
      "deDE",
      "enUS"
    ],
    "name": "polyfill-bundler",
    "tagline": "",
    "trackingCode": ""
  },
  "keywords": [
    "polyfill",
    "bundle",
    "service"
  ],
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thaibault/polyfill-bundler"
  },
  "scripts": {
    "build": "yarn build:types; yarn build:plain",
    "build:lint": "babel --presets @babel/preset-typescript --source-maps inline --out-file eslint.config.mjs eslint.config.ts",
    "build:plain": "babel --plugins @babel/plugin-transform-runtime --presets @babel/preset-env,@babel/preset-typescript --source-maps inline --out-file index.js index.ts && sed --in-place --regexp-extended 's:^// *(#![^ ]+ ).*$:\\1node:' index.js && chmod +x index.js",
    "build:types": "tsc --emitDeclarationOnly",
    "check:types": "tsc --noEmit",
    "clear": "rimraf --glob 'eslint.config.d.ts' 'index.d.ts' '*.js'",
    "lint": "yarn build:lint && eslint",
    "serve": "./index.js",
    "start": "yarn serve",
    "update:documentation": "web-documentation"
  },
  "devDependencies": {
    "@babel/cli": "^7.28.6",
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/eslint": "^9.6.1",
    "@types/polyfill-library": "^3.108.4",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "web-documentation": "^1.0.2"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "clientnode": "^4.0.1388",
    "polyfill-library": "^4.8.0"
  },
  "engines": {
    "node": ">=24",
    "npm": ">=11",
    "yarn": ">=4"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
